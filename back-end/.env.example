# Backend env file — copy to `.env` and fill in real values.
# `.env` is gitignored — never commit it.

# ---- Server ----
# Port the Express server listens on. Defaults to 5000 if unset.
PORT=5000

# Frontend URL embedded in outgoing emails (e.g. the verify-email link).
# Use http://localhost:3000 in dev; your real domain in production.
BASE_URL=http://localhost:3000

# ---- Database ----
# MongoDB Atlas connection string.
# Get one from https://cloud.mongodb.com → your cluster → "Connect" → "Drivers".
# Replace <username>, <password>, and <cluster> below.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# ---- Auth ----
# Used to sign JWT tokens. MUST be a long random string. Anyone with this value
# can forge auth tokens for any user — treat it like a password.
# Generate one: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=replace-me-with-a-long-random-string

# ---- Email (Gmail) ----
# Gmail account used to send verification + password-reset emails.
EMAIL_USER=your.email@gmail.com

# Gmail App Password — NOT your account password.
# Create one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification on the Google account.)
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
